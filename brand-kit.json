  "logo": {
    "description": "Das Logo setzt sich aus einem vorangestellten Signet (Bildmarke), einer Wortmarke und einem optionalen Slogan (Subline) zusammen.",
    "variants": [
      {
        "name": "Bildmarke",
        "description": "Reduzierte Version (nur Signet) für kompakte Anwendungen"
      },
      {
        "name": "Standardversion",
        "description": "Bildmarke kombiniert mit Wortmarke – die bevorzugte Variante"
      },
      {
        "name": "Subline",
        "description": "Standardversion ergänzt um den Slogan"
      }
    ],
    "construction": {
      "principle": "Geometrisches Konstruktionsprinzip basierend auf der Schrift Neue Kabel",
      "cornerRadiusRatio": "1:32 (r zur Bildmarke)",
      "innerRadiusRatio": "1:16 (F/r Verhältnis)"
    },
    "allowedBackgrounds": ["#ffffff", "#000000", "#001f33"],
    "clearSpace": {
      "description": "Das Logo besitzt einen Schutzraum, der nach Möglichkeit eingehalten werden muss. Der Eckenradius der Hintergrundfläche ist Bestandteil des Logos, sofern die Hintergrundfläche nicht größer als der Schutzraum ist."
    },
    "dosAndDonts": {
      "do": [
        "Logo nur in den freigegebenen Varianten verwenden.",
        "Schutzraum einhalten.",
        "Logo auf Weiß, Schwarz oder Midnight Dreams platzieren oder auf einer Fläche, die zur Schutzraumfarbe kontrastiert/harmoniert."
      ],
      "dont": [
        "Logo nicht verzerren oder strecken.",
        "Farben des Logos nicht verändern.",
        "Keine zusätzlichen Elemente zum Logo hinzufügen.",
        "Logo nicht auf ungeeigneten Hintergründen platzieren."
      ]
    }
  },
  "designPrinciples": [
    "Innovation und Offenheit – offene, schwebende Formsprache",
